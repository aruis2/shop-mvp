{
    "compilerOptions": {
        "target": "ES2020",
        "module": "none",
        "lib": ["ES2020", "DOM"],
        "outDir": ".",
        "rootDir": "ts",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "sourceMap": false,
        "declaration": false
    },
    "include": ["ts/**/*.ts"]
}
