# =============================================================================
# .env.example — Template pentru variabile de mediu
# =============================================================================
# Copiază în .env și completează valorile:
#   cp .env.example .env
#
# Pentru criptare: bash scripts/secrets.sh encrypt
# =============================================================================

# --- Baza de date ---
DATABASE_URL=postgresql://postgres:PAROLA@localhost:5432/test

# --- Mediu ---
APP_ENV=dev                          # dev | prod
APP_FEATURES=knowledge_base
SITE_URL=http://localhost:3001

# --- API Keys ---
DEEPSEEK_API_KEY=sk-your-key-here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here

# --- Autentificare ---
JWT_SECRET=change-this-to-a-random-secret

# --- Limitări ---
MAX_QTY_PER_PRODUCT=20

# --- Debug (doar dev) ---
RUST_LOG=debug
RUST_BACKTRACE=full
